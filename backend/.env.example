# ------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit .env.
# ------------------------------------------------------------------

# --- App ---
APP_ENV=development                 # development | production
FRONTEND_ORIGIN=http://localhost:5173

# --- Supabase (Project Settings -> API & Database) ---
# Postgres connection string (use the "Connection Pooling" / Transaction URI for prod).
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
# JWT secret used to verify Supabase-issued access tokens (Settings -> API -> JWT Secret).
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- Groq (add as many keys as you have, comma-separated) ---
# The backend rotates across these automatically on rate-limit / failure.
GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google OAuth (added later, for Gmail/Calendar automations) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
