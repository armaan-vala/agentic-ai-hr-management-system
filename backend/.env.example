# ------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit .env.
# ------------------------------------------------------------------

# --- App ---
APP_ENV=development                 # development | production
FRONTEND_ORIGIN=http://localhost:5173

# --- Database (Supabase -> Connect -> Session pooler URI) ---
# Note the `+asyncpg` driver prefix.
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# --- Supabase (Settings -> API Keys) ---
SUPABASE_URL=https://PROJECT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx         # browser-safe
SUPABASE_SECRET_KEY=sb_secret_xxx            # backend only (admin user creation)

# --- Groq (add as many keys as you have, comma-separated) ---
GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google OAuth (Gmail send / Calendar) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/google/callback
GOOGLE_POST_CONNECT_REDIRECT=http://localhost:5173/settings?google=connected

# --- Secrets (generate your own: see below) ---
# APP_SECRET:            python -c "import secrets; print(secrets.token_hex(32))"
# TOKEN_ENCRYPTION_KEY:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET=change-me
TOKEN_ENCRYPTION_KEY=change-me-fernet-key
